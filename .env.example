# Images
API_IMAGE=jobapp-api
WORKER_IMAGE=jobapp-worker
FRONTEND_IMAGE=jobapp-frontend
IMAGE_TAG=latest

# Ports
API_PORT=8000
FRONTEND_PORT=3000

# Redis
REDIS_HOST=redis
